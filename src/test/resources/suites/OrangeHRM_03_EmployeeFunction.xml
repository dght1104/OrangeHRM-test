<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Employee Function">
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="OrangeHRM.listeners.AllureListener" />
    </listeners>
    <test name="Add New Employee">
        <classes>
            <class name="OrangeHRM.testcases.employee.verifyThatUserCanAddNewEmployee"/>
        </classes>
    </test>
    <test name="Add Multiple Employees">
        <classes>
            <class name="OrangeHRM.testcases.employee.verifyThatUserCanAddMultipleEmployees"/>
        </classes>
    </test>
    <test name = "Delete Employee">
        <classes>
            <class name="OrangeHRM.testcases.employee.verifyThatUserCanDeleteEmployee"/>
        </classes>
    </test>
</suite>